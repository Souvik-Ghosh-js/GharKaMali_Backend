# Server
PORT=3000
NODE_ENV=development

# Database (AWS Lightsail MySQL)
DB_HOST=your-lightsail-mysql-host
DB_PORT=3306
DB_NAME=gharkamali
DB_USER=root
DB_PASSWORD=your-db-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=30d

# OTP (Static for dev, MSG91 for prod)
USE_STATIC_OTP=true
STATIC_OTP=123456
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=GHRMALI
MSG91_TEMPLATE_ID=your-template-id

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# File Storage (Lightsail)
UPLOAD_PATH=/var/www/uploads
BASE_URL=http://your-lightsail-ip:3000

# AI Plant Identification (Plant.id API - https://plant.id)
PLANT_ID_API_KEY=your-plant-id-api-key

# Frontend URLs
ADMIN_URL=http://your-admin-domain
CUSTOMER_APP_URL=http://your-customer-domain

# Razorpay Payment Gateway (Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook signing secret (Dashboard → Settings → Webhooks) — verifies webhook authenticity
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

FRONTEND_URL=http://your-customer-app-domain

# Email / SMTP (for career application notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=finance@gharkamali.com
SMTP_PASS=meny neto dpav hzqu
SMTP_FROM="GharKaMali" <finance@gharkamali.com>
ADMIN_EMAIL=info@gharkamali.com
# Finance team mailbox — every paid booking / subscription / order is emailed here
FINANCE_EMAIL=finance@gharkamali.com
# Branding for finance/notification emails. EMAIL_LOGO_URL must be a PUBLIC https
# image URL (email clients block relative/localhost paths). Leave it blank to use
# a 🌿 text wordmark instead. The logo lives on your website at /logo.png.
EMAIL_LOGO_URL=https://gharkamali.com/logo.png
BRAND_NAME=GharKaMali
BRAND_TAGLINE=Your Garden, Our Care
BRAND_SITE=https://gharkamali.com
