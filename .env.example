# Server
PORT=3000
NODE_ENV=development

# Database (AWS Lightsail MySQL)
DB_HOST=your-lightsail-mysql-host
DB_PORT=3306
DB_NAME=gharkamali
DB_USER=root
DB_PASSWORD=your-db-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=30d

# OTP (Static for dev, MSG91 for prod)
USE_STATIC_OTP=true
STATIC_OTP=123456
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=GHRMALI
MSG91_TEMPLATE_ID=your-template-id

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# File Storage (Lightsail)
UPLOAD_PATH=/var/www/uploads
BASE_URL=http://your-lightsail-ip:3000

# AI Plant Identification (Plant.id API - https://plant.id)
PLANT_ID_API_KEY=your-plant-id-api-key

# Frontend URLs
ADMIN_URL=http://your-admin-domain
CUSTOMER_APP_URL=http://your-customer-domain

# PayU Payment Gateway
PAYU_MERCHANT_KEY=your-payu-merchant-key
PAYU_MERCHANT_SALT=your-payu-merchant-salt
PAYU_MODE=test
# test URL: https://test.payu.in/_payment
# prod URL: https://secure.payu.in/_payment

FRONTEND_URL=http://your-customer-app-domain
