{
  "openapi": "3.0.0",
  "info": {
    "title": "Ghar Ka Mali API",
    "version": "2.0.0",
    "description": "Complete gardening platform API — 83 endpoints"
  },
  "servers": [
    { "url": "http://YOUR_LIGHTSAIL_IP:3000/api", "description": "Production (Lightsail)" },
    { "url": "http://localhost:3000/api", "description": "Local Development" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  },
  "tags": [
    {"name": "Auth"}, {"name": "Bookings"}, {"name": "Gardener"},
    {"name": "Subscriptions"}, {"name": "Plans"}, {"name": "Zones"},
    {"name": "Payments"}, {"name": "Plantopedia"}, {"name": "Content"},
    {"name": "Notifications"}, {"name": "Complaints"}, {"name": "Add-Ons"},
    {"name": "Admin"}, {"name": "SLA"}, {"name": "Supervisor"}
  ],
  "paths": {
    "/auth/send-otp":           { "post": { "tags":["Auth"], "summary":"Send OTP to phone", "requestBody":{"content":{"application/json":{"schema":{"properties":{"phone":{"type":"string","example":"9876543210"}}}}}}, "responses":{"200":{"description":"OTP sent (static: 123456 in dev)"}} } },
    "/auth/verify-otp":         { "post": { "tags":["Auth"], "summary":"Verify OTP → login or register customer", "requestBody":{"content":{"application/json":{"schema":{"properties":{"phone":{"type":"string"},"otp":{"type":"string","example":"123456"},"name":{"type":"string"}}}}}}, "responses":{"200":{"description":"JWT token + user"}} } },
    "/auth/admin-login":        { "post": { "tags":["Auth"], "summary":"Admin/Supervisor password login", "requestBody":{"content":{"application/json":{"schema":{"properties":{"phone":{"type":"string"},"password":{"type":"string"}}}}}}, "responses":{"200":{"description":"JWT token"}} } },
    "/auth/gardener-login":     { "post": { "tags":["Auth"], "summary":"Gardener OTP login", "requestBody":{"content":{"application/json":{"schema":{"properties":{"phone":{"type":"string"},"otp":{"type":"string"}}}}}}, "responses":{"200":{"description":"JWT + gardener profile"}} } },
    "/auth/gardener-register":  { "post": { "tags":["Auth"], "summary":"Gardener registration (multipart)", "requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"name":{"type":"string"},"phone":{"type":"string"},"email":{"type":"string"},"experience_years":{"type":"integer"},"bio":{"type":"string"},"service_zone_ids":{"type":"array","items":{"type":"integer"}},"profile_image":{"type":"string","format":"binary"},"id_proof":{"type":"string","format":"binary"}}}}}}, "responses":{"201":{"description":"Submitted, awaiting approval"}} } },
    "/auth/profile":            { "get":{"tags":["Auth"],"summary":"Get current user profile","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"User + gardener profile if applicable"}}}, "put":{"tags":["Auth"],"summary":"Update profile","security":[{"bearerAuth":[]}],"requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"name":{"type":"string"},"email":{"type":"string"},"address":{"type":"string"},"profile_image":{"type":"string","format":"binary"}}}}}},"responses":{"200":{"description":"Updated user"}}} },

    "/plans":                   { "get": { "tags":["Plans"], "summary":"Get all active service plans", "responses":{"200":{"description":"Plans list"}} } },
    "/zones":                   { "get": { "tags":["Zones"], "summary":"Get all active service zones", "responses":{"200":{"description":"Zones with pricing"}} } },
    "/addons":                  { "get": { "tags":["Add-Ons"], "summary":"Get all active add-on services", "responses":{"200":{"description":"Add-ons grouped by category"}} } },

    "/payments/check-serviceability": { "get": { "tags":["Payments"], "summary":"Check if lat/lng is in serviceable zone", "parameters":[{"name":"latitude","in":"query","required":true,"schema":{"type":"number"}},{"name":"longitude","in":"query","required":true,"schema":{"type":"number"}}], "responses":{"200":{"description":"serviceable: bool, zones: []"}} } },
    "/payments/initiate":       { "post": { "tags":["Payments"], "summary":"Initiate PayU payment", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"type":{"type":"string","enum":["booking","subscription","wallet_topup"]},"booking_id":{"type":"integer"},"subscription_id":{"type":"integer"},"amount":{"type":"number"}}}}}}, "responses":{"200":{"description":"PayU params + payment_id"}} } },
    "/payments/success":        { "post": { "tags":["Payments"], "summary":"PayU success callback (called by PayU)", "responses":{"302":{"description":"Redirect to frontend"}} } },
    "/payments/failure":        { "post": { "tags":["Payments"], "summary":"PayU failure callback (called by PayU)", "responses":{"302":{"description":"Redirect to frontend"}} } },
    "/payments/status/{txnid}": { "get": { "tags":["Payments"], "summary":"Check payment status by transaction ID", "security":[{"bearerAuth":[]}], "parameters":[{"name":"txnid","in":"path","required":true,"schema":{"type":"string"}}], "responses":{"200":{"description":"Payment record"}} } },
    "/payments/my":             { "get": { "tags":["Payments"], "summary":"Get my payment history", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"Paginated payments"}} } },
    "/payments/wallet-topup":   { "post": { "tags":["Payments"], "summary":"Initiate wallet top-up via PayU", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"amount":{"type":"number","minimum":100}}}}}}, "responses":{"200":{"description":"PayU params"}} } },
    "/payments/reschedule":     { "post": { "tags":["Bookings"], "summary":"Reschedule a booking", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"booking_id":{"type":"integer"},"new_date":{"type":"string","format":"date"},"new_time":{"type":"string"}}}}}}, "responses":{"200":{"description":"Rescheduled booking"}} } },

    "/bookings":                { "post": { "tags":["Bookings"], "summary":"Create on-demand booking", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"required":["zone_id","scheduled_date","service_address","service_latitude","service_longitude"],"properties":{"zone_id":{"type":"integer"},"scheduled_date":{"type":"string","format":"date"},"scheduled_time":{"type":"string"},"service_address":{"type":"string"},"service_latitude":{"type":"number"},"service_longitude":{"type":"number"},"plant_count":{"type":"integer"},"preferred_gardener_id":{"type":"integer"},"customer_notes":{"type":"string"}}}}}}, "responses":{"201":{"description":"Booking with OTP"}} } },
    "/bookings/my":             { "get": { "tags":["Bookings"], "summary":"Get my bookings (customer)", "security":[{"bearerAuth":[]}], "parameters":[{"name":"status","in":"query","schema":{"type":"string"}},{"name":"page","in":"query","schema":{"type":"integer"}}], "responses":{"200":{"description":"Paginated bookings"}} } },
    "/bookings/{id}":           { "get": { "tags":["Bookings"], "summary":"Get booking detail", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"Full booking with gardener & zone"}} } },
    "/bookings/verify-otp":     { "post": { "tags":["Gardener"], "summary":"Verify visit OTP to start job", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"booking_id":{"type":"integer"},"otp":{"type":"string"}}}}}}, "responses":{"200":{"description":"Visit started"}} } },
    "/bookings/status":         { "put": { "tags":["Gardener"], "summary":"Update booking status + work proof images", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"booking_id":{"type":"integer"},"status":{"type":"string","enum":["en_route","arrived","in_progress","completed","failed"]},"gardener_notes":{"type":"string"},"extra_plants":{"type":"integer"},"before_image":{"type":"string","format":"binary"},"after_image":{"type":"string","format":"binary"}}}}}}, "responses":{"200":{"description":"Status updated"}} } },
    "/bookings/rate":           { "post": { "tags":["Bookings"], "summary":"Rate a completed booking (1-5 stars)", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"booking_id":{"type":"integer"},"rating":{"type":"integer","minimum":1,"maximum":5},"review":{"type":"string"}}}}}}, "responses":{"200":{"description":"Rated, gardener avg updated"}} } },
    "/bookings/cancel":         { "post": { "tags":["Bookings"], "summary":"Cancel a booking", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"booking_id":{"type":"integer"},"reason":{"type":"string"}}}}}}, "responses":{"200":{"description":"Cancelled"}} } },
    "/bookings/location":       { "post": { "tags":["Gardener"], "summary":"Update gardener GPS location", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"latitude":{"type":"number"},"longitude":{"type":"number"},"booking_id":{"type":"integer"}}}}}}, "responses":{"200":{"description":"Location saved + Socket.io broadcast"}} } },
    "/bookings/track/{booking_id}": { "get": { "tags":["Bookings"], "summary":"Get gardener current location for tracking", "security":[{"bearerAuth":[]}], "parameters":[{"name":"booking_id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"lat/lng + last_updated"}} } },
    "/bookings/gardener/jobs":  { "get": { "tags":["Gardener"], "summary":"Get gardener's assigned jobs", "security":[{"bearerAuth":[]}], "parameters":[{"name":"status","in":"query","schema":{"type":"string"}},{"name":"date","in":"query","schema":{"type":"string","format":"date"}},{"name":"page","in":"query","schema":{"type":"integer"}}], "responses":{"200":{"description":"Jobs list"}} } },
    "/bookings/gardener/earnings": { "get": { "tags":["Gardener"], "summary":"Gardener earnings breakdown by period", "security":[{"bearerAuth":[]}], "parameters":[{"name":"period","in":"query","schema":{"type":"string","enum":["daily","weekly","monthly"]}}], "responses":{"200":{"description":"Breakdown + totals"}} } },
    "/bookings/{id}/addons":    { "get":{"tags":["Add-Ons"],"summary":"Get add-ons for a booking","security":[{"bearerAuth":[]}],"parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Add-ons list"}}}, "post":{"tags":["Add-Ons"],"summary":"Add extra services to a booking","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"properties":{"addon_ids":{"type":"array","items":{"type":"object","properties":{"addon_id":{"type":"integer"},"quantity":{"type":"integer"}}}}}}}}},"responses":{"200":{"description":"Add-ons attached, total updated"}}} },

    "/subscriptions":           { "post": { "tags":["Subscriptions"], "summary":"Purchase a subscription plan", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"required":["plan_id","service_address","service_latitude","service_longitude"],"properties":{"plan_id":{"type":"integer"},"zone_id":{"type":"integer"},"service_address":{"type":"string"},"service_latitude":{"type":"number"},"service_longitude":{"type":"number"},"plant_count":{"type":"integer"},"preferred_gardener_id":{"type":"integer"},"auto_renew":{"type":"boolean"}}}}}}, "responses":{"201":{"description":"Subscription + auto-scheduled visits"}} } },
    "/subscriptions/my":        { "get": { "tags":["Subscriptions"], "summary":"Get my subscriptions", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"Subscriptions with plan details"}} } },
    "/subscriptions/{id}/cancel": { "put": { "tags":["Subscriptions"], "summary":"Cancel subscription", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"Cancelled"}} } },

    "/plants/identify":         { "post": { "tags":["Plantopedia"], "summary":"AI plant identification from image", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"image":{"type":"string","format":"binary"}}}}}}, "responses":{"200":{"description":"Plant name, care guide, watering schedule, fertilizer tips"}} } },
    "/plants/history":          { "get": { "tags":["Plantopedia"], "summary":"Get my plant identification history", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"History list"}} } },

    "/blogs":                   { "get": { "tags":["Content"], "summary":"Get published blogs (SSG)", "parameters":[{"name":"page","in":"query","schema":{"type":"integer"}},{"name":"category","in":"query","schema":{"type":"string"}},{"name":"city_slug","in":"query","schema":{"type":"string"}}], "responses":{"200":{"description":"Paginated blogs"}} } },
    "/blogs/{slug}":            { "get": { "tags":["Content"], "summary":"Get blog post by slug", "parameters":[{"name":"slug","in":"path","required":true,"schema":{"type":"string"}}], "responses":{"200":{"description":"Full blog post, views incremented"}} } },
    "/cities":                  { "get": { "tags":["Content"], "summary":"Get active city SEO pages", "responses":{"200":{"description":"City list"}} } },
    "/cities/{slug}":           { "get": { "tags":["Content"], "summary":"Get city page by slug", "parameters":[{"name":"slug","in":"path","required":true,"schema":{"type":"string"}}], "responses":{"200":{"description":"City SEO page"}} } },

    "/notifications":           { "get": { "tags":["Notifications"], "summary":"Get my notifications", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"30 most recent"}} } },
    "/notifications/{id}/read": { "put": { "tags":["Notifications"], "summary":"Mark notification as read", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"Marked"}} } },

    "/complaints":              { "post":{"tags":["Complaints"],"summary":"Raise a complaint (customer)","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["type","description"],"properties":{"booking_id":{"type":"integer"},"type":{"type":"string","enum":["service_quality","late_arrival","no_show","rude_behavior","billing","damage","other"]},"description":{"type":"string"},"priority":{"type":"string","enum":["low","medium","high"]}}}}}},"responses":{"201":{"description":"Complaint raised, supervisor notified via WhatsApp"}}}, "get":{"tags":["Complaints"],"summary":"Get all complaints (admin/supervisor)","security":[{"bearerAuth":[]}],"parameters":[{"name":"status","in":"query","schema":{"type":"string"}},{"name":"priority","in":"query","schema":{"type":"string"}}],"responses":{"200":{"description":"Complaints list"}}} },
    "/complaints/my":           { "get": { "tags":["Complaints"], "summary":"Get my complaints (customer)", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"Customer complaints"}} } },
    "/complaints/stats":        { "get": { "tags":["Complaints"], "summary":"Complaint stats (admin/supervisor)", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"open/inReview/resolved/highPriority counts"}} } },
    "/complaints/{id}":         { "put": { "tags":["Complaints"], "summary":"Update complaint — assign/resolve (admin/supervisor)", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"status":{"type":"string"},"resolution_notes":{"type":"string"},"assigned_to":{"type":"integer"}}}}}}, "responses":{"200":{"description":"Updated, customer notified"}} } },

    "/supervisor/dashboard":    { "get": { "tags":["Supervisor"], "summary":"Supervisor team dashboard", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"Team gardeners + today stats"}} } },

    "/admin/dashboard":         { "get": { "tags":["Admin"], "summary":"Admin overview stats", "security":[{"bearerAuth":[]}], "responses":{"200":{"description":"Stats + recent bookings"}} } },
    "/admin/analytics":         { "get": { "tags":["Admin"], "summary":"Full analytics data", "security":[{"bearerAuth":[]}], "parameters":[{"name":"period","in":"query","schema":{"type":"string","default":"30"},"description":"Days to look back"},{"name":"zone_id","in":"query","schema":{"type":"integer"}}], "responses":{"200":{"description":"Revenue, zones, cities, users, plans, ratings, repeat customers"}} } },
    "/admin/utilization":       { "get": { "tags":["Admin"], "summary":"Gardener utilization rate report", "security":[{"bearerAuth":[]}], "parameters":[{"name":"period","in":"query","schema":{"type":"string","default":"30"}}], "responses":{"200":{"description":"Per-gardener utilization % + summary"}} } },
    "/admin/gardeners":         { "get":{"tags":["Admin"],"summary":"List gardeners with filter","security":[{"bearerAuth":[]}],"parameters":[{"name":"status","in":"query","schema":{"type":"string","enum":["pending","active","inactive",""]}},{"name":"search","in":"query","schema":{"type":"string"}},{"name":"city","in":"query","schema":{"type":"string"}}],"responses":{"200":{"description":"Paginated gardeners with profiles"}}} },
    "/admin/gardeners/approve": { "post": { "tags":["Admin"], "summary":"Approve gardener + assign supervisor", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"user_id":{"type":"integer"},"supervisor_id":{"type":"integer"}}}}}}, "responses":{"200":{"description":"Approved, WhatsApp sent"}} } },
    "/admin/gardeners/reject":  { "post": { "tags":["Admin"], "summary":"Reject gardener application", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"properties":{"user_id":{"type":"integer"},"reason":{"type":"string"}}}}}}, "responses":{"200":{"description":"Rejected"}} } },
    "/admin/supervisors":       { "get":{"tags":["Admin"],"summary":"List supervisors","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Supervisors list"}}}, "post":{"tags":["Admin"],"summary":"Create supervisor account","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["name","phone","password"],"properties":{"name":{"type":"string"},"phone":{"type":"string"},"email":{"type":"string"},"password":{"type":"string"}}}}}},"responses":{"201":{"description":"Supervisor created"}}} },
    "/admin/zones":             { "get":{"tags":["Admin"],"summary":"List all zones","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Zones"}}}, "post":{"tags":["Admin"],"summary":"Create service zone","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["name","city","state","base_price"],"properties":{"name":{"type":"string"},"city":{"type":"string"},"state":{"type":"string"},"base_price":{"type":"number"},"price_per_plant":{"type":"number"},"center_latitude":{"type":"number"},"center_longitude":{"type":"number"},"radius_km":{"type":"number"}}}}}},"responses":{"201":{"description":"Zone created"}}} },
    "/admin/zones/{id}":        { "put": { "tags":["Admin"], "summary":"Update zone", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "requestBody":{"content":{"application/json":{"schema":{}}}}, "responses":{"200":{"description":"Updated"}} } },
    "/admin/plans":             { "post": { "tags":["Admin"], "summary":"Create service plan", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"required":["name","price"],"properties":{"name":{"type":"string"},"plan_type":{"type":"string","enum":["subscription","ondemand"]},"price":{"type":"number"},"visits_per_month":{"type":"integer"},"max_plants":{"type":"integer"},"duration_days":{"type":"integer"}}}}}}, "responses":{"201":{"description":"Plan created"}} } },
    "/admin/plans/{id}":        { "put": { "tags":["Admin"], "summary":"Update plan (logs price change)", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "requestBody":{"content":{"application/json":{"schema":{}}}}, "responses":{"200":{"description":"Updated + PriceHikeLog if price changed"}} } },
    "/admin/bookings":          { "get": { "tags":["Admin"], "summary":"List all bookings with filters", "security":[{"bearerAuth":[]}], "parameters":[{"name":"status","in":"query","schema":{"type":"string"}},{"name":"zone_id","in":"query","schema":{"type":"integer"}},{"name":"date","in":"query","schema":{"type":"string"}},{"name":"gardener_id","in":"query","schema":{"type":"integer"}}], "responses":{"200":{"description":"Paginated bookings"}} } },
    "/admin/subscriptions":     { "get": { "tags":["Admin"], "summary":"List all subscriptions", "security":[{"bearerAuth":[]}], "parameters":[{"name":"status","in":"query","schema":{"type":"string"}}], "responses":{"200":{"description":"Paginated subscriptions"}} } },
    "/admin/customers":         { "get": { "tags":["Admin"], "summary":"List customers", "security":[{"bearerAuth":[]}], "parameters":[{"name":"search","in":"query","schema":{"type":"string"}},{"name":"city","in":"query","schema":{"type":"string"}}], "responses":{"200":{"description":"Paginated customers"}} } },
    "/admin/rewards":           { "get":{"tags":["Admin"],"summary":"List rewards/penalties","security":[{"bearerAuth":[]}],"parameters":[{"name":"gardener_id","in":"query","schema":{"type":"integer"}},{"name":"type","in":"query","schema":{"type":"string","enum":["reward","penalty"]}}],"responses":{"200":{"description":"Paginated rewards/penalties"}}}, "post":{"tags":["Admin"],"summary":"Create manual reward or penalty","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["gardener_id","type","amount","reason"],"properties":{"gardener_id":{"type":"integer"},"type":{"type":"string","enum":["reward","penalty"]},"amount":{"type":"number"},"reason":{"type":"string"},"booking_id":{"type":"integer"}}}}}}, "responses":{"201":{"description":"Created + earnings updated"}}} },
    "/admin/payments":          { "get": { "tags":["Admin"], "summary":"List all PayU transactions", "security":[{"bearerAuth":[]}], "parameters":[{"name":"status","in":"query","schema":{"type":"string"}},{"name":"type","in":"query","schema":{"type":"string"}}], "responses":{"200":{"description":"Paginated payments"}} } },
    "/admin/price-hike":        { "post": { "tags":["Admin"], "summary":"Apply immediate price hike to zones/plans", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"required":["percentage"],"properties":{"percentage":{"type":"number"},"reason":{"type":"string"},"zone_ids":{"type":"array","items":{"type":"integer"}},"plan_ids":{"type":"array","items":{"type":"integer"}}}}}}}, "responses":{"200":{"description":"Applied + PriceHikeLog created"}} } },
    "/admin/price-hike/schedule": { "post":{"tags":["Admin"],"summary":"Schedule a future price hike","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["percentage","scheduled_at"],"properties":{"name":{"type":"string"},"percentage":{"type":"number"},"scheduled_at":{"type":"string","format":"date-time"},"reason":{"type":"string"},"zone_ids":{"type":"array","items":{"type":"integer"}},"plan_ids":{"type":"array","items":{"type":"integer"}}}}}}},"responses":{"201":{"description":"Scheduled (runs via daily cron)"}}}, "get":{"tags":["Admin"],"summary":"List scheduled price hikes","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Scheduled hikes"}}} },
    "/admin/price-hike/schedule/{id}": { "delete": { "tags":["Admin"], "summary":"Delete pending scheduled hike", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"Deleted"}} } },
    "/admin/blogs":             { "post":{"tags":["Admin"],"summary":"Create blog post","security":[{"bearerAuth":[]}],"requestBody":{"content":{"multipart/form-data":{"schema":{"properties":{"title":{"type":"string"},"content":{"type":"string"},"category":{"type":"string"},"status":{"type":"string","enum":["draft","published"]},"seo_title":{"type":"string"},"seo_description":{"type":"string"},"city_slug":{"type":"string"},"featured_image":{"type":"string","format":"binary"}}}}}},"responses":{"201":{"description":"Blog created"}}} },
    "/admin/blogs/{id}":        { "put":{"tags":["Admin"],"summary":"Update blog post","security":[{"bearerAuth":[]}],"parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}],"requestBody":{"content":{"multipart/form-data":{"schema":{}}}},"responses":{"200":{"description":"Updated"}}}, "delete":{"tags":["Admin"],"summary":"Archive blog","security":[{"bearerAuth":[]}],"parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}],"responses":{"200":{"description":"Archived"}}} },
    "/admin/cities":            { "post": { "tags":["Admin"], "summary":"Create or update city SEO page", "security":[{"bearerAuth":[]}], "requestBody":{"content":{"application/json":{"schema":{"required":["city_name"],"properties":{"city_name":{"type":"string"},"state":{"type":"string"},"hero_title":{"type":"string"},"hero_description":{"type":"string"},"content":{"type":"string"},"seo_title":{"type":"string"},"seo_description":{"type":"string"}}}}}}, "responses":{"200":{"description":"City page saved"}} } },
    "/admin/addons":            { "get":{"tags":["Add-Ons"],"summary":"List all add-on services (admin)","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"Full catalog"}}}, "post":{"tags":["Add-Ons"],"summary":"Create add-on service","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"required":["name","price"],"properties":{"name":{"type":"string"},"description":{"type":"string"},"price":{"type":"number"},"duration_mins":{"type":"integer"},"icon":{"type":"string"},"category":{"type":"string"}}}}}},"responses":{"201":{"description":"Created"}}} },
    "/admin/addons/{id}":       { "put": { "tags":["Add-Ons"], "summary":"Update add-on service", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "requestBody":{"content":{"application/json":{"schema":{}}}}, "responses":{"200":{"description":"Updated"}} } },
    "/admin/sla/config":        { "get":{"tags":["SLA"],"summary":"Get SLA config","security":[{"bearerAuth":[]}],"responses":{"200":{"description":"max_arrival_delay_mins, max_service_duration_hrs, response_time_hrs"}}}, "put":{"tags":["SLA"],"summary":"Update SLA thresholds","security":[{"bearerAuth":[]}],"requestBody":{"content":{"application/json":{"schema":{"properties":{"max_arrival_delay_mins":{"type":"integer"},"max_service_duration_hrs":{"type":"number"},"response_time_hrs":{"type":"integer"}}}}}},"responses":{"200":{"description":"Updated"}}} },
    "/admin/sla/breaches":      { "get": { "tags":["SLA"], "summary":"List SLA breaches", "security":[{"bearerAuth":[]}], "parameters":[{"name":"is_resolved","in":"query","schema":{"type":"boolean"}},{"name":"breach_type","in":"query","schema":{"type":"string"}}], "responses":{"200":{"description":"Breaches with booking + gardener"}} } },
    "/admin/sla/breaches/{id}/resolve": { "put": { "tags":["SLA"], "summary":"Mark SLA breach as resolved", "security":[{"bearerAuth":[]}], "parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"integer"}}], "responses":{"200":{"description":"Resolved"}} } }
  }
}
